{
  "workspace-mcp": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@microsoft/workiq"],
    "env": {
      "WORKIQ_CLIENT_ID": "${{ secrets.COPILOT_WORKSPACE_CLIENT_ID }}",
      "WORKIQ_CLIENT_SECRET": "${{ secrets.COPILOT_WORKSPACE_CLIENT_SECRET }}",
      "WORKIQ_TENANT_ID": "${{ secrets.COPILOT_WORKSPACE_TENANT_ID }}"
    }
  }
}
