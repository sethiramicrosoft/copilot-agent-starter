{
  "mail-mcp": {
    "type": "local",
    "command": "npx",
    "args": [
      "-y",
      "@microsoft/workiq"
    ],
    "tools": [
      "*"
    ],
    "env": {
      "WORKIQ_CLIENT_ID": "${{ secrets.COPILOT_MAIL_CLIENT_ID }}",
      "WORKIQ_CLIENT_SECRET": "${{ secrets.COPILOT_MAIL_CLIENT_SECRET }}",
      "WORKIQ_TENANT_ID": "${{ secrets.COPILOT_MAIL_TENANT_ID }}"
    }
  }
}
