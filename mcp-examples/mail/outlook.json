{
  "mail-mcp": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-outlook"],
    "env": {
      "OUTLOOK_CLIENT_ID": "${{ secrets.COPILOT_MAIL_CLIENT_ID }}",
      "OUTLOOK_CLIENT_SECRET": "${{ secrets.COPILOT_MAIL_CLIENT_SECRET }}",
      "OUTLOOK_TENANT_ID": "${{ secrets.COPILOT_MAIL_TENANT_ID }}"
    }
  }
}
