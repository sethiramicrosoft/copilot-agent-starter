{
  "mail-mcp": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-gmail"],
    "env": {
      "GMAIL_CLIENT_ID": "${{ secrets.COPILOT_MAIL_CLIENT_ID }}",
      "GMAIL_CLIENT_SECRET": "${{ secrets.COPILOT_MAIL_CLIENT_SECRET }}",
      "GMAIL_REFRESH_TOKEN": "${{ secrets.COPILOT_MAIL_TENANT_ID }}"
    }
  }
}
